rules_version = '2';

// ════════════════════════════════════════════════════════════
// Firestore Security Rules — Rx-COPD/Asthma Clinic
// Firebase Authentication เปิดใช้แล้ว — require auth ทุก request
// Deploy: firebase deploy --only firestore:rules
// ════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── ข้อมูลคลินิกหลัก (/clinic/main) ──
    // อนุญาตเฉพาะผู้ใช้ที่ผ่าน Firebase Authentication เท่านั้น
    match /clinic/{docId} {
      allow read: if request.auth != null;
      allow create, update: if
        request.auth != null &&
        request.resource.data.size() < 1500 &&
        request.resource.size < 2 * 1024 * 1024;
      allow delete: if false;
    }

    // ── Auto-backup slots (หมุนเวียน 10 ช่อง) ──
    match /clinic_backups/{slot} {
      allow read: if request.auth != null;
      allow create, update: if
        request.auth != null &&
        request.resource.size < 2 * 1024 * 1024;
      allow delete: if false;
    }

    // ปฏิเสธทุกอย่างที่เหลือ
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
